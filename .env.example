# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dqmp?schema=public

# Docker PostgreSQL Configuration (for docker-compose)
POSTGRES_USER=dqmp
POSTGRES_PASSWORD=dqmp_password
POSTGRES_DB=dqmp
POSTGRES_PORT=5432

# Application Configuration
NODE_ENV=development
PORT=3001
# For Azure App Service Linux use: /home/site/wwwroot/uploads
UPLOAD_DIR=uploads

# JWT Secret (Change this to a strong random string in production!)
JWT_SECRET=change-this-to-a-strong-random-secret-minimum-32-characters

# Frontend CORS Origins (comma-separated)
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5173

# SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@dqmp.com

# Twilio Configuration (Optional - for SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SLT SMS Configuration (Production SMS Gateway)
SLT_SMS_USERNAME=E00682
SLT_SMS_PASSWORD=E00682@123
SLT_SMS_ALIAS=SLTM QMS
SLT_SMS_API_URL=https://smsc.slt.lk:8093/api/sms
# Set to 'slt' to use SLT SMS, 'twilio' for Twilio, or 'both' for fallback
SMS_PROVIDER=slt

# Performance & Logging
LOG_LEVEL=info
PERF_LOG=true
PERF_LOG_THRESHOLD_MS=200
COMPRESS_THRESHOLD=1024

# Queue Configuration
LONG_WAIT_MINUTES=10

# Redis Configuration (Optional - for future use)
REDIS_PORT=6379
