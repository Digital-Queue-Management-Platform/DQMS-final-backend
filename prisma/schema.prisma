generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id                String             @id @default(uuid())
  name              String
  mobileNumber      String
  createdAt         DateTime           @default(now())
  sltMobileNumber   String?
  nicNumber         String?
  email             String?
  completedServices CompletedService[]
  feedbacks         Feedback[]
  serviceCases      ServiceCase[]
  tokens            Token[]

  @@index([mobileNumber])
}

model Token {
  id                 String             @id @default(uuid())
  tokenNumber        Int
  customerId         String
  preferredLanguages Json?
  accountRef         String?
  status             String             @default("waiting")
  outletId           String
  assignedTo         String?
  counterNumber      Int?
  createdAt          DateTime           @default(now())
  calledAt           DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  serviceTypes          String[]           @default([]) @map("serviceType")
  isPriority            Boolean            @default(false)
  isTransferred         Boolean            @default(false)
  sltTelephoneNumber    String?
  billPaymentIntent     String?
  billPaymentAmount     Float?
  billPaymentMethod     String?
  completedServices  CompletedService[]
  feedback           Feedback?
  serviceCases       ServiceCase[]
  transferLogs       TransferLog[]
  officer            Officer?           @relation(fields: [assignedTo], references: [id])
  customer           Customer           @relation(fields: [customerId], references: [id])
  outlet             Outlet             @relation(fields: [outletId], references: [id])

  @@index([outletId, status])
  @@index([assignedTo])
  @@index([outletId, status, createdAt, tokenNumber])
}

model TeleshopManager {
  id                String             @id @default(uuid())
  name              String
  mobileNumber      String             @unique
  regionId          String
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  lastLoginAt       DateTime?
  email             String?
  branchId          String?
  completedServices CompletedService[]
  auditLogs         TeleshopManagerAuditLog[]
  branch            Outlet?            @relation(fields: [branchId], references: [id])
  region            Region             @relation(fields: [regionId], references: [id])

  @@index([regionId])
  @@index([mobileNumber])
  @@index([branchId])
}

model Officer {
  id                String             @id @default(uuid())
  name              String
  mobileNumber      String             @unique
  outletId          String
  status            String             @default("offline")
  counterNumber     Int?
  isTraining        Boolean            @default(false)
  createdAt         DateTime           @default(now())
  lastLoginAt       DateTime?
  assignedServices  Json?
  languages         Json?
  BreakLog          BreakLog[]
  completedServices CompletedService[]
  outlet            Outlet             @relation(fields: [outletId], references: [id])
  serviceCases      ServiceCase[]
  tokens            Token[]
  transferLogs      TransferLog[]

  @@index([outletId, status])
}

model Outlet {
  id                String             @id @default(uuid())
  name              String
  location          String
  regionId          String
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  counterCount      Int?               @default(0)
  kioskPassword     String?
  displaySettings   Json?

  appointments      Appointment[]
  closureNotices    ClosureNotice[]
  completedServices CompletedService[]
  managerQRTokens   ManagerQRToken[]
  officers          Officer[]
  region            Region             @relation(fields: [regionId], references: [id])
  serviceCases      ServiceCase[]
  teleshopManagers  TeleshopManager[]
  tokens            Token[]
}

model Region {
  id               String            @id @default(uuid())
  name             String
  managerId        String?
  managerEmail     String?
  managerMobile    String?
  managerLastLoginAt DateTime?
  createdAt        DateTime          @default(now())
  managerPassword  String?
  outlets          Outlet[]
  teleshopManagers TeleshopManager[]
}

model Feedback {
  id                String    @id @default(uuid())
  tokenId           String    @unique
  customerId        String
  rating            Int
  comment           String?
  createdAt         DateTime  @default(now())
  assignedTo        String?
  assignedToId      String?
  isResolved        Boolean   @default(false)
  resolutionComment String?
  resolvedAt        DateTime?
  resolvedBy        String?
  customer          Customer  @relation(fields: [customerId], references: [id])
  token             Token     @relation(fields: [tokenId], references: [id])

  @@index([rating])
  @@index([createdAt])
  @@index([assignedTo, assignedToId])
}

model Document {
  id            String   @id @default(uuid())
  filename      String
  filepath      String
  mimeType      String
  size          Int
  uploadedBy    String
  relatedEntity String
  createdAt     DateTime @default(now())

  @@index([relatedEntity])
}

model Alert {
  id            String   @id @default(uuid())
  type          String
  severity      String
  message       String
  relatedEntity String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([isRead, createdAt])
}

model Service {
  id                String             @id @default(uuid())
  code              String             @unique
  title             String
  description       String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  order             Int                @default(999)
  isPriorityService Boolean            @default(false)
  completedServices CompletedService[]

  @@index([order])
}

model AppSetting {
  id           String   @id @default(uuid())
  key          String   @unique
  booleanValue Boolean?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CompletedService {
  id                String           @id @default(uuid())
  tokenId           String
  serviceId         String
  officerId         String
  teleshopManagerId String?
  customerId        String
  outletId          String
  duration          Int?
  notes             String?
  completedAt       DateTime         @default(now())
  customer          Customer         @relation(fields: [customerId], references: [id])
  officer           Officer          @relation(fields: [officerId], references: [id])
  outlet            Outlet           @relation(fields: [outletId], references: [id])
  service           Service          @relation(fields: [serviceId], references: [id])
  teleshopManager   TeleshopManager? @relation(fields: [teleshopManagerId], references: [id])
  token             Token            @relation(fields: [tokenId], references: [id])

  @@index([teleshopManagerId, completedAt])
  @@index([officerId, completedAt])
  @@index([outletId, completedAt])
}

model BreakLog {
  id        String    @id
  officerId String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  Officer   Officer   @relation(fields: [officerId], references: [id])

  @@index([officerId, startedAt])
}

model TransferLog {
  id                   String   @id @default(uuid())
  tokenId              String
  fromOfficerId        String
  fromCounterNumber    Int?
  toCounterNumber      Int?
  previousServiceTypes String[]
  newServiceTypes      String[]
  notes                String?
  createdAt            DateTime @default(now())
  token                Token    @relation(fields: [tokenId], references: [id])
  fromOfficer          Officer  @relation(fields: [fromOfficerId], references: [id])

  @@index([tokenId])
  @@index([fromOfficerId, createdAt])
}

model TeleshopManagerAuditLog {
  id                String          @id @default(uuid())
  teleshopManagerId String
  action            String
  entityType        String?
  entityId          String?
  details           Json?
  createdAt         DateTime        @default(now())
  teleshopManager   TeleshopManager @relation(fields: [teleshopManagerId], references: [id])

  @@index([teleshopManagerId, createdAt])
  @@index([action, createdAt])
}

model ManagerQRToken {
  token       String   @id
  outletId    String
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  outlet      Outlet   @relation(fields: [outletId], references: [id])

  @@index([outletId])
}

model Appointment {
  id                 String    @id @default(uuid())
  name               String
  mobileNumber       String
  outletId           String
  serviceTypes       String[]
  preferredLanguage  String?
  appointmentAt      DateTime
  status             String    @default("booked")
  tokenId            String?
  notes              String?
  createdAt          DateTime  @default(now())
  queuedAt           DateTime?
  completedAt        DateTime?
  sltTelephoneNumber String?
  billPaymentIntent  String?
  billPaymentAmount  Float?
  billPaymentMethod  String?
  outlet             Outlet    @relation(fields: [outletId], references: [id])

  @@index([outletId, appointmentAt])
  @@index([mobileNumber, appointmentAt])
  @@index([status, appointmentAt])
}

model ServiceCase {
  id                String              @id @default(uuid())
  refNumber         String              @unique
  tokenId           String
  outletId          String
  officerId         String
  teleshopManagerId String?
  customerId        String
  serviceTypes      String[]
  status            String              @default("open")
  createdAt         DateTime            @default(now())
  completedAt       DateTime?
  lastUpdatedAt     DateTime            @default(now())
  customer          Customer            @relation(fields: [customerId], references: [id])
  officer           Officer             @relation(fields: [officerId], references: [id])
  outlet            Outlet              @relation(fields: [outletId], references: [id])
  token             Token               @relation(fields: [tokenId], references: [id])
  updates           ServiceCaseUpdate[]

  @@index([refNumber])
  @@index([outletId, createdAt])
}

model ServiceCaseUpdate {
  id          String      @id @default(uuid())
  caseId      String
  actorRole   String
  actorId     String?
  status      String?
  note        String
  createdAt   DateTime    @default(now())
  serviceCase ServiceCase @relation(fields: [caseId], references: [id])

  @@index([caseId, createdAt])
}

model SltBill {
  id              String    @id @default(uuid())
  telephoneNumber String    @unique
  accountName     String
  accountAddress  String?
  currentBill     Float
  dueDate         DateTime
  status          String    @default("unpaid")
  lastPaymentDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  mobileNumber    String?

  @@index([telephoneNumber])
  @@index([status, dueDate])
}

model GM {
  id           String    @id @default(uuid())
  name         String
  mobileNumber String    @unique
  email        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
  dgms         DGM[]

  @@index([mobileNumber])
}

model DGM {
  id           String    @id @default(uuid())
  name         String
  mobileNumber String    @unique
  email        String?
  gmId         String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
  regionIds    String[]
  gm           GM        @relation(fields: [gmId], references: [id])

  @@index([mobileNumber])
  @@index([gmId])
}

model ClosureNotice {
  id                 String    @id @default(uuid())
  outletId           String
  title              String
  message            String
  startsAt           DateTime
  endsAt             DateTime
  createdBy          String
  createdById        String
  createdAt          DateTime  @default(now())
  noticeType         String    @default("closure")
  isRecurring        Boolean   @default(false)
  recurringType      String?
  recurringDays      String[]  @default([])
  recurringEndDate   DateTime?
  recurringStartTime String?
  recurringEndTime   String?
  outlet             Outlet    @relation(fields: [outletId], references: [id])

  @@index([outletId, endsAt])
  @@index([isRecurring, recurringType])
}

model MercantileHoliday {
  id          String   @id @default(uuid())
  date        DateTime
  name        String
  createdAt   DateTime @default(now())
  isRecurring Boolean  @default(false)

  @@index([date])
}

model OTP {
  id           String   @id @default(uuid())
  mobileNumber String
  otpCode      String
  userType     String
  expiresAt    DateTime
  verified     Boolean  @default(false)
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([mobileNumber, userType, verified])
  @@index([expiresAt])
}
