generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id                String             @id @default(uuid())
  name              String
  mobileNumber      String
  createdAt         DateTime           @default(now())
  sltMobileNumber   String?
  nicNumber         String?
  email             String?
  completedServices CompletedService[]
  feedbacks         Feedback[]
  serviceCases      ServiceCase[]
  tokens            Token[]

  @@index([mobileNumber])
}

model Token {
  id                       String             @id @default(uuid())
  tokenNumber              Int
  customerId               String
  preferredLanguages       Json?
  accountRef               String?
  status                   String             @default("waiting")
  outletId                 String
  assignedTo               String?
  counterNumber            Int?
  createdAt                DateTime           @default(now())
  calledAt                 DateTime?
  startedAt                DateTime?
  completedAt              DateTime?
  serviceTypes             String[]           @default([]) @map("serviceType")
  isPriority               Boolean            @default(false)
  billPaymentAmount        Float?
  billPaymentIntent        String?
  billPaymentMethod        String?
  isTransferred            Boolean            @default(false)
  sltTelephoneNumber       String?
  billPaymentCustomAmounts Json?
  completedServices        CompletedService[]
  feedback                 Feedback?
  serviceCases             ServiceCase[]
  officer                  Officer?           @relation(fields: [assignedTo], references: [id])
  customer                 Customer           @relation(fields: [customerId], references: [id])
  outlet                   Outlet             @relation(fields: [outletId], references: [id])
  tokenBills               TokenBill[]
  transferLogs             TransferLog[]

  @@index([outletId, status])
  @@index([assignedTo])
  @@index([outletId, status, createdAt, tokenNumber])
}

model TeleshopManager {
  id                String                    @id @default(uuid())
  name              String
  mobileNumber      String                    @unique
  regionId          String
  isActive          Boolean                   @default(true)
  createdAt         DateTime                  @default(now())
  lastLoginAt       DateTime?
  email             String?
  branchId          String?
  rtomId            String?
  completedServices CompletedService[]
  branch            Outlet?                   @relation(fields: [branchId], references: [id])
  region            Region                    @relation(fields: [regionId], references: [id])
  rtom              RTOM?                     @relation(fields: [rtomId], references: [id])
  auditLogs         TeleshopManagerAuditLog[]

  @@index([regionId])
  @@index([mobileNumber])
  @@index([branchId])
  @@index([rtomId])
}

model Officer {
  id                String             @id @default(uuid())
  name              String
  mobileNumber      String             @unique
  outletId          String
  status            String             @default("offline")
  counterNumber     Int?
  isTraining        Boolean            @default(false)
  createdAt         DateTime           @default(now())
  lastLoginAt       DateTime?
  assignedServices  Json?
  languages         Json?
  email             String?
  BreakLog          BreakLog[]
  completedServices CompletedService[]
  outlet            Outlet             @relation(fields: [outletId], references: [id])
  serviceCases      ServiceCase[]
  tokens            Token[]
  transferLogs      TransferLog[]

  @@index([outletId, status])
}

model Outlet {
  id                String             @id @default(uuid())
  name              String
  location          String
  regionId          String
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  counterCount      Int?               @default(0)
  kioskPassword     String?
  displaySettings   Json?
  provinceId        String?
  rtomId            String?
  appointments      Appointment[]
  auditLogs         AuditLog[]
  closureNotices    ClosureNotice[]
  completedServices CompletedService[]
  deviceHeartbeats  DeviceHeartbeat[]
  deviceLinks       DeviceLink[]
  managerQRTokens   ManagerQRToken[]
  officers          Officer[]
  province          Province?          @relation(fields: [provinceId], references: [id])
  region            Region             @relation(fields: [regionId], references: [id])
  RTOM              RTOM?              @relation(fields: [rtomId], references: [id])
  qrSessions        QRSession[]
  serviceCases      ServiceCase[]
  systemLogs        SystemLog[]
  teleshopManagers  TeleshopManager[]
  tokens            Token[]

  @@index([rtomId])
}

model Region {
  id                 String            @id @default(uuid())
  name               String
  managerId          String?
  managerEmail       String?
  managerMobile      String?
  createdAt          DateTime          @default(now())
  managerPassword    String?
  managerLastLoginAt DateTime?
  gmId               String?           @unique
  auditLogs          AuditLog[]
  gm                 GM?
  outlets            Outlet[]
  provinces          Province[]
  rtoms              RTOM[]
  systemLogs         SystemLog[]
  teleshopManagers   TeleshopManager[]
}

model Province {
  id        String   @id @default(uuid())
  name      String
  regionId  String
  createdAt DateTime @default(now())
  dgm       DGM?
  outlets   Outlet[]
  region    Region   @relation(fields: [regionId], references: [id])

  @@index([regionId])
}

model Feedback {
  id                String    @id @default(uuid())
  tokenId           String    @unique
  customerId        String
  rating            Int
  comment           String?
  createdAt         DateTime  @default(now())
  assignedTo        String?
  assignedToId      String?
  isResolved        Boolean   @default(false)
  resolutionComment String?
  resolvedAt        DateTime?
  resolvedBy        String?
  customer          Customer  @relation(fields: [customerId], references: [id])
  token             Token     @relation(fields: [tokenId], references: [id])

  @@index([rating])
  @@index([createdAt])
  @@index([assignedTo, assignedToId])
}

model Document {
  id            String   @id @default(uuid())
  filename      String
  filepath      String
  mimeType      String
  size          Int
  uploadedBy    String
  relatedEntity String
  createdAt     DateTime @default(now())

  @@index([relatedEntity])
}

model Alert {
  id            String   @id @default(uuid())
  type          String
  severity      String
  message       String
  relatedEntity String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  outletId      String?

  @@index([isRead, createdAt])
  @@index([outletId])
}

model BackupRestoreHistory {
  id            String   @id @default(uuid())
  action        String
  status        String   @default("success")
  filename      String?
  totalRecords  Int      @default(0)
  tableCounts   Json?
  errorMessage  String?
  createdByRole String?
  createdById   String?
  createdAt     DateTime @default(now())

  @@index([action, createdAt])
  @@index([status, createdAt])
}

model Service {
  id                String             @id @default(uuid())
  code              String             @unique
  title             String
  description       String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  order             Int                @default(999)
  isPriorityService Boolean            @default(false)
  requireOtp        Boolean            @default(false)
  completedServices CompletedService[]

  @@index([order])
}

model AppSetting {
  id           String   @id @default(uuid())
  key          String   @unique
  booleanValue Boolean?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CompletedService {
  id                String           @id @default(uuid())
  tokenId           String
  serviceId         String
  officerId         String
  teleshopManagerId String?
  customerId        String
  outletId          String
  duration          Int?
  notes             String?
  completedAt       DateTime         @default(now())
  customer          Customer         @relation(fields: [customerId], references: [id])
  officer           Officer          @relation(fields: [officerId], references: [id])
  outlet            Outlet           @relation(fields: [outletId], references: [id])
  service           Service          @relation(fields: [serviceId], references: [id])
  teleshopManager   TeleshopManager? @relation(fields: [teleshopManagerId], references: [id])
  token             Token            @relation(fields: [tokenId], references: [id])

  @@index([teleshopManagerId, completedAt])
  @@index([officerId, completedAt])
  @@index([outletId, completedAt])
}

model BreakLog {
  id        String    @id
  officerId String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  Officer   Officer   @relation(fields: [officerId], references: [id])

  @@index([officerId, startedAt])
}

model TransferLog {
  id                   String   @id @default(uuid())
  tokenId              String
  fromOfficerId        String
  fromCounterNumber    Int?
  toCounterNumber      Int?
  previousServiceTypes String[]
  newServiceTypes      String[]
  notes                String?
  createdAt            DateTime @default(now())
  fromOfficer          Officer  @relation(fields: [fromOfficerId], references: [id])
  token                Token    @relation(fields: [tokenId], references: [id])

  @@index([tokenId])
  @@index([fromOfficerId, createdAt])
}

model TeleshopManagerAuditLog {
  id                String          @id @default(uuid())
  teleshopManagerId String
  action            String
  entityType        String?
  entityId          String?
  details           Json?
  createdAt         DateTime        @default(now())
  teleshopManager   TeleshopManager @relation(fields: [teleshopManagerId], references: [id])

  @@index([teleshopManagerId, createdAt])
  @@index([action, createdAt])
}

model ManagerQRToken {
  token       String   @id
  outletId    String
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  outlet      Outlet   @relation(fields: [outletId], references: [id])

  @@index([outletId])
}

model Appointment {
  id                 String            @id @default(uuid())
  name               String
  mobileNumber       String
  outletId           String
  serviceTypes       String[]
  preferredLanguage  String?
  appointmentAt      DateTime
  status             String            @default("booked")
  tokenId            String?
  notes              String?
  createdAt          DateTime          @default(now())
  queuedAt           DateTime?
  completedAt        DateTime?
  sltTelephoneNumber String?
  billPaymentAmount  Float?
  billPaymentIntent  String?
  billPaymentMethod  String?
  reminder1hSentAt   DateTime?
  reminder30mSentAt  DateTime?
  outlet             Outlet            @relation(fields: [outletId], references: [id])
  appointmentBills   AppointmentBill[]

  @@index([outletId, appointmentAt])
  @@index([mobileNumber, appointmentAt])
  @@index([status, appointmentAt])
}

model ServiceCase {
  id                String              @id @default(uuid())
  refNumber         String              @unique
  tokenId           String
  outletId          String
  officerId         String
  teleshopManagerId String?
  customerId        String
  serviceTypes      String[]
  status            String              @default("open")
  createdAt         DateTime            @default(now())
  completedAt       DateTime?
  lastUpdatedAt     DateTime            @default(now())
  customer          Customer            @relation(fields: [customerId], references: [id])
  officer           Officer             @relation(fields: [officerId], references: [id])
  outlet            Outlet              @relation(fields: [outletId], references: [id])
  token             Token               @relation(fields: [tokenId], references: [id])
  updates           ServiceCaseUpdate[]

  @@index([refNumber])
  @@index([outletId, createdAt])
}

model ServiceCaseUpdate {
  id          String      @id @default(uuid())
  caseId      String
  actorRole   String
  actorId     String?
  status      String?
  note        String
  createdAt   DateTime    @default(now())
  serviceCase ServiceCase @relation(fields: [caseId], references: [id])

  @@index([caseId, createdAt])
}

model SltBill {
  id               String            @id @default(uuid())
  telephoneNumber  String            @unique
  accountName      String
  accountAddress   String?
  currentBill      Float
  dueDate          DateTime
  status           String            @default("unpaid")
  lastPaymentDate  DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  mobileNumber     String?
  appointmentBills AppointmentBill[]
  tokenBills       TokenBill[]

  @@index([telephoneNumber])
  @@index([status, dueDate])
}

model TokenBill {
  id                String   @id @default(uuid())
  tokenId           String
  telephoneNumber   String
  billPaymentIntent String?
  billPaymentAmount Float?
  createdAt         DateTime @default(now())
  sltBill           SltBill  @relation(fields: [telephoneNumber], references: [telephoneNumber])
  token             Token    @relation(fields: [tokenId], references: [id])

  @@unique([tokenId, telephoneNumber])
  @@index([tokenId])
  @@index([telephoneNumber])
}

model AppointmentBill {
  id                String      @id @default(uuid())
  appointmentId     String
  telephoneNumber   String
  billPaymentIntent String?
  billPaymentAmount Float?
  createdAt         DateTime    @default(now())
  appointment       Appointment @relation(fields: [appointmentId], references: [id])
  sltBill           SltBill     @relation(fields: [telephoneNumber], references: [telephoneNumber])

  @@unique([appointmentId, telephoneNumber])
  @@index([appointmentId])
  @@index([telephoneNumber])
}

model GM {
  id           String    @id @default(uuid())
  name         String
  mobileNumber String    @unique
  email        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
  password     String
  regionId     String?   @unique
  dgms         DGM[]
  region       Region?   @relation(fields: [regionId], references: [id])

  @@index([mobileNumber])
}

model DGM {
  id           String    @id @default(uuid())
  name         String
  mobileNumber String    @unique
  email        String?
  gmId         String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
  regionIds    String[]
  provinceId   String?   @unique
  gm           GM        @relation(fields: [gmId], references: [id])
  province     Province? @relation(fields: [provinceId], references: [id])
  rtoms        RTOM[]

  @@index([mobileNumber])
  @@index([gmId])
}

model RTOM {
  id               String            @id @default(uuid())
  name             String
  mobileNumber     String            @unique
  email            String?
  dgmId            String
  regionId         String
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  lastLoginAt      DateTime?
  Outlet           Outlet[]
  dgm              DGM               @relation(fields: [dgmId], references: [id])
  region           Region            @relation(fields: [regionId], references: [id])
  teleshopManagers TeleshopManager[]

  @@index([mobileNumber])
  @@index([dgmId])
  @@index([regionId])
}

model ClosureNotice {
  id                 String    @id @default(uuid())
  outletId           String
  title              String
  message            String
  startsAt           DateTime
  endsAt             DateTime
  createdBy          String
  createdById        String
  createdAt          DateTime  @default(now())
  isRecurring        Boolean   @default(false)
  recurringType      String?
  recurringDays      String[]  @default([])
  recurringEndDate   DateTime?
  recurringStartTime String?
  recurringEndTime   String?
  noticeType         String    @default("closure")
  outlet             Outlet    @relation(fields: [outletId], references: [id])

  @@index([outletId, endsAt])
  @@index([isRecurring, recurringType])
}

model MercantileHoliday {
  id          String   @id @default(uuid())
  date        DateTime
  name        String
  createdAt   DateTime @default(now())
  isRecurring Boolean  @default(false)

  @@index([date])
}

model OTP {
  id           String   @id @default(uuid())
  mobileNumber String
  otpCode      String
  userType     String
  expiresAt    DateTime
  verified     Boolean  @default(false)
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([mobileNumber, userType, verified])
  @@index([expiresAt])
}

model SystemLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  level      String
  service    String
  module     String?
  event      String?
  message    String
  stackTrace String?
  metadata   Json?
  userId     String?
  userRole   String?
  outletId   String?
  regionId   String?
  deviceId   String?
  sessionId  String?
  requestId  String?
  appVersion String?
  ipAddress  String?
  userAgent  String?
  outlet     Outlet?  @relation(fields: [outletId], references: [id])
  region     Region?  @relation(fields: [regionId], references: [id])

  @@index([timestamp])
  @@index([level, timestamp])
  @@index([service, timestamp])
  @@index([outletId, timestamp])
  @@index([userId, timestamp])
  @@index([event, timestamp])
  @@index([level, service, timestamp])
}

model DeviceHeartbeat {
  id                 String    @id @default(uuid())
  deviceId           String    @unique
  deviceType         String
  outletId           String
  status             String    @default("online")
  appVersion         String?
  websocketConnected Boolean   @default(false)
  pollingMode        Boolean   @default(false)
  ipAddress          String?
  lastSeenAt         DateTime  @default(now())
  lastError          String?
  lastErrorAt        DateTime?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  outlet             Outlet    @relation(fields: [outletId], references: [id])

  @@index([outletId, status])
  @@index([deviceType, status])
  @@index([lastSeenAt])
  @@index([status, lastSeenAt])
}

model DeploymentLog {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  service      String
  environment  String   @default("production")
  branch       String?
  commitHash   String?
  status       String
  triggeredBy  String?
  duration     Int?
  output       String?
  errorMessage String?
  notes        String?

  @@index([timestamp])
  @@index([service, timestamp])
  @@index([status, timestamp])
}

model AuditLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  userId     String
  userRole   String
  action     String
  targetType String?
  targetId   String?
  outletId   String?
  regionId   String?
  changes    Json?
  metadata   Json?
  message    String
  ipAddress  String?
  outlet     Outlet?  @relation(fields: [outletId], references: [id])
  region     Region?  @relation(fields: [regionId], references: [id])

  @@index([timestamp])
  @@index([userId, timestamp])
  @@index([action, timestamp])
  @@index([outletId, timestamp])
  @@index([userRole, timestamp])
}

model QRSession {
  id                 String    @id @default(uuid())
  sessionId          String    @unique
  qrToken            String    @unique
  outletId           String
  deviceId           String?
  deviceName         String?
  status             String    @default("pending")
  generatedAt        DateTime  @default(now())
  expiresAt          DateTime
  scannedAt          DateTime?
  scannedByManagerId String?
  linkedAt           DateTime?
  linkedManagerId    String?
  linkedDeviceId     String?
  unlinkedAt         DateTime?
  unlinkedBy         String?
  unlinkedReason     String?
  metadata           Json?
  outlet             Outlet    @relation(fields: [outletId], references: [id])

  @@index([sessionId])
  @@index([qrToken])
  @@index([outletId, status])
  @@index([status, expiresAt])
  @@index([generatedAt])
  @@index([linkedManagerId])
}

model DeviceLink {
  id              String    @id @default(uuid())
  deviceId        String    @unique
  deviceName      String
  macAddress      String?
  outletId        String
  managerId       String
  status          String    @default("active")
  linkedAt        DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  lastHeartbeatAt DateTime?
  unlinkedAt      DateTime?
  configData      Json?
  metadata        Json?
  outlet          Outlet    @relation(fields: [outletId], references: [id])

  @@index([deviceId])
  @@index([outletId, status])
  @@index([managerId])
  @@index([status, lastSeenAt])
  @@index([lastSeenAt])
}

model DailyActionTracker {
  id           String   @id
  mobileNumber String
  date         String
  count        Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@unique([mobileNumber, date])
  @@index([mobileNumber, date])
}
